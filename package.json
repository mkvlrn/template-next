{
  "name": "template-next",
  "description": "A esm template for Next.js projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@proton.me>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-next"
  },
  "keywords": ["nextjs", "esm", "template"],
  "scripts": {
    "swc": "node --import @swc-node/register/esm-register",
    "build": "npx next build",
    "dev": "npx next dev",
    "start": "npx next start",
    "test": "npm run swc -- scripts/test.ts",
    "test:cov": "npm run swc -- scripts/test.ts --coverage",
    "tidy": "npm run swc -- scripts/tidy.ts",
    "typecheck": "npx tsc --noEmit",
    "prepare": "npx husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@swc-node/register": "^1.10.9",
    "@swc/cli": "^0.5.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {}
    }
  }
}
