{
  "name": "template-next",
  "description": "A template for Next.js projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-next"
  },
  "keywords": [
    "node",
    "template"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:cov": "rm -rf coverage && vitest run --coverage",
    "prepare": "husky",
    "dev": "next dev",
    "build": "rm -rf dist && NODE_ENV=production next build",
    "start": "NODE_ENV=production next start"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@mkvlrn/eslint-config": "^24.6.5",
    "@mkvlrn/prettier-config": "^24.6.1",
    "@next/eslint-plugin-next": "^14.2.3",
    "@swc/plugin-transform-imports": "^2.0.4",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.12.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "next": "^14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
